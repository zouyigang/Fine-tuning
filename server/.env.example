# ===== 数据库 =====
# 开发默认 SQLite（免安装，开箱即跑）
DATABASE_URL=sqlite:///./finetune.db
# 切换到 MySQL：取消下行注释并改成你的连接串（pymysql 已在依赖中）
# DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/finetune?charset=utf8mb4

# ===== 鉴权（P2）=====
JWT_SECRET=change-me-in-prod
JWT_EXPIRE_MINUTES=720

# ===== 其它 =====
# 允许的前端来源（CORS）
CORS_ORIGINS=http://localhost:5180
# 启动时若库为空自动灌入种子数据
AUTO_SEED=true

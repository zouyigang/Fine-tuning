# 后端 CUDA 镜像（ENGINE_MODE=real，真实 LLaMA-Factory 微调）
# 宿主仅需最新 N 卡驱动 + nvidia-container-toolkit；CUDA/cuDNN 随 torch wheel 进镜像。
# 见 docs/真实微调引擎方案.md。用法见 docker-compose.gpu.yml。
FROM python:3.12-slim

ENV PYTHONUNBUFFERED=1 \
    PYTHONUTF8=1 \
    ENGINE_MODE=real

WORKDIR /app

# 1) torch 全家桶（CUDA 13.0，支持 Blackwell/sm_120；wheel 自带 CUDA+cuDNN，宿主只需驱动）
#    必须 torch / torchaudio / torchvision 同版本、同 CUDA 源——否则 llamafactory 启动时
#    无条件 import torchaudio 会因 CUDA 版本不一致直接报错退出。torchaudio 目前最高 2.11.0，
#    cu132 源也没有 torchaudio；故整套锁 2.11.0+cu130（与本机已验证跑通 Qwen3 的配置一致）。
# 多 GB wheel + pypi.nvidia.com 较慢：加大重试/超时 + BuildKit pip 缓存挂载，
# 已下完的 wheel（如 cudnn 366MB）跨构建复用，中断重试不必从头下载。
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --retries 10 --timeout 600 \
        torch==2.11.0 torchaudio==2.11.0 torchvision==0.26.0 \
        --index-url https://download.pytorch.org/whl/cu130

# 2) LLaMA-Factory（真实训练引擎，锁定正式版）
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install llamafactory==0.9.5

# 3) 应用依赖（清华源；含 PyYAML / nvidia-ml-py 等）
COPY requirements.txt .
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install -i https://pypi.tuna.tsinghua.edu.cn/simple -r requirements.txt

COPY . .

EXPOSE 8000

# 启动前迁移建表，再启服务
CMD ["sh", "-c", "alembic upgrade head && uvicorn app.main:app --host 0.0.0.0 --port 8000"]
